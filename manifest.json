{
  "manifest_version": 3,
  "name": "No Work We Trade",
  "version": "1.0",
  "description": "OTC Trading Assistant",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.pocketoption.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.pocketoption.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
